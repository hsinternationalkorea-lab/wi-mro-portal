# Supabase (필수)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...

# 이메일 발송 (Phase 2)
RESEND_API_KEY=
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=

# 외부 API (Phase 2)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
MOUSER_API_KEY=
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# OpenAI (Phase 2 — 임베딩, 부품 식별)
OPENAI_API_KEY=
