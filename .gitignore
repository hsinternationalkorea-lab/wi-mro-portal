# =====================================================================
# 보안 — 절대 push 금지 (Supabase key, 쿠키, 비번 등)
# =====================================================================
_secrets/
*.env
.env
.env.*
!.env.example

# =====================================================================
# 크롤링 출력 — 용량 큰 파일/캐시
# =====================================================================
output/
*.log
*.png
*.jpg
*.jpeg
*.gif

# 단, output 폴더 안의 의미있는 결과(JSON 분석 등)는 제외
!output/.keep
!output/**/analysis.json

# =====================================================================
# Python 표준
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 가상환경
venv/
.venv/
env/
ENV/

# =====================================================================
# IDE
# =====================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# =====================================================================
# Streamlit
# =====================================================================
.streamlit/secrets.toml

# =====================================================================
# 일시 작업 / 백업
# =====================================================================
*.bak
*.tmp
*.old
~$*
